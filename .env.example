# Alya TTS Microservice - Environment Configuration
# Copy this file to .env and fill in your values

# Telegram Bot Token (required for sending voice messages back)
BOT_TOKEN=your_telegram_bot_token_here

# General
DEFAULT_LANGUAGE=en
LOG_LEVEL=INFO

# Voice Model Paths
VOICE_ENABLED=true
VOICE_MODEL_DIR=alya_voice

# RVC Engine Configuration
RVC_ENABLED=true
RVC_DEVICE=cpu
RVC_CPU_THREADS=3
RVC_IS_HALF=false
RVC_PITCH_CHANGE=0
RVC_F0_METHOD=rmvpe
RVC_INDEX_RATE=0.75
RVC_VOLUME_ENVELOPE=1.0
RVC_PROTECT=0.33
RVC_RESAMPLE_SR=0
RVC_QUEUE_SIZE=2

# TTS Service
TTS_PORT=5001
TTS_IDLE_TIMEOUT=120
TTS_SEND_TIMEOUT=120
